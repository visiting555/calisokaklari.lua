-- Server Hop (Sunucu Değiştirme) Fonksiyonu:
local function serverHop()
    local HttpService = game:GetService("HttpService")
    local TeleportService = game:GetService("TeleportService")
    local PlaceId = game.PlaceId

    local function getServers(cursor)
        local url = "https://games.roblox.com/v1/games/" .. PlaceId .. "/servers/Public?sortOrder=Asc&limit=100"
        if cursor then
            url = url .. "&cursor=" .. cursor
        end
        local suc, res = pcall(function()
            return HttpService:JSONDecode(game:HttpGet(url))
        end)
        if suc and res then
            return res
        end
        return nil
    end

    local myJobId = game.JobId
    local found = false
    local minPlayersServer

    local nextPage = nil
    repeat
        local servers = getServers(nextPage)
        if servers then
            for _,server in ipairs(servers.data) do
                if server.playing < server.maxPlayers and server.id ~= myJobId then
                    if not minPlayersServer or server.playing < minPlayersServer.playing then
                        minPlayersServer = server
                    end
                end
            end
            nextPage = servers.nextPageCursor
        else
            nextPage = nil
        end
    until not nextPage or minPlayersServer

    if minPlayersServer then
        notify("Sunucudan çıkılıyor... (Sunucu atlanıyor)")
        wait(1)
        TeleportService:TeleportToPlaceInstance(PlaceId, minPlayersServer.id, game.Players.LocalPlayer)
    else
        notify("Uygun sunucu bulunamadı!")
    end
end

