local function findAllFruitsByName(fruitName)
    local found = {}
    for _,obj in pairs(Workspace:GetChildren()) do
        if obj:IsA("Tool") and obj.Name:lower():find("fruit") and obj.Handle and obj:FindFirstChild("FruitName") then
            local fname = obj:FindFirstChild("FruitName").Value
            if fname:lower():find(fruitName:lower()) then
                table.insert(found, obj)
            end
        elseif obj:IsA("Tool") and obj.Name:lower():find(fruitName:lower()) then -- fallback
            table.insert(found, obj)
        end
    end
    -- Also check FruitSpawn if exists
    if Workspace:FindFirstChild("FruitSpawn") then
        for _,v in pairs(Workspace.FruitSpawn:GetChildren()) do
            if v:IsA("Tool") and v:FindFirstChild("FruitName") and v.FruitName.Value:lower():find(fruitName:lower()) then
                table.insert(found, v)
            end
        end
    end
    return found
end

local function countServerFruits()
    -- returns a dictionary: { ["Kitsune"]=2, ... }
    local tbl = {}
    for _,fruit in ipairs(FruitNames) do tbl[fruit] = 0 end
    for _,obj in pairs(Workspace:GetChildren()) do
        if obj:IsA("Tool") and obj.Handle and obj:FindFirstChild("FruitName") then
            local fname = obj.FruitName.Value
            for _,iname in ipairs(FruitNames) do
                if fname:lower():find(iname:lower()) then
                    tbl[iname] = tbl[iname]+1
                end
            end
        elseif obj:IsA("Tool") then
            for _,iname in ipairs(FruitNames) do
                if obj.Name:lower():find(iname:lower()) then
                    tbl[iname] = tbl[iname]+1
                end
            end
        end
    end
    if Workspace:FindFirstChild("FruitSpawn") then
        for _,obj in pairs(Workspace.FruitSpawn:GetChildren()) do
            if obj:IsA("Tool") and obj:FindFirstChild("FruitName") then
                local fname = obj.FruitName.Value
                for _,iname in ipairs(FruitNames) do
                    if fname:lower():find(iname:lower()) then
                        tbl[iname] = tbl[iname]+1
                    end
                end
            end
        end
    end
    return tbl
end

